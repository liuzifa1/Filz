    "Allow Access": {
      "extractionState": "stale",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセスを許可"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许访问"
          }
        }
      }
    },
    "Allow add-only Photos access if you want Filz to save received photos and videos to your library. Filz can add new items but can’t read your existing library.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "受信した写真やビデオをライブラリに保存するには、写真への追加のみのアクセスを許可してください。Filzは新しい項目を追加できますが、既存のライブラリを読み取ることはできません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你希望 Filz 将收到的照片和视频保存到照片图库，请允许“仅添加照片”访问权限。Filz 可以添加新项目，但无法读取你现有的图库。"
          }
        }
      }
    },
    "Allow Local Network Access": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルネットワークへのアクセスを許可"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许访问本地网络"
          }
        }
      }
    },
    "Allow Photos Access": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真へのアクセスを許可"
          }
        },
        "zh-Hans": {
          "stringUnit": {
