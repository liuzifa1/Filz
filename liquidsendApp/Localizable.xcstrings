    "Applying this restarts the LocalSend server so nearby devices see the new name.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "適用するとLocalSendサーバーが再起動し、近くのデバイスに新しい名前が表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用后将重启 LocalSend 服务器，以便附近设备看到新名称。"
          }
        }
      }
    },
