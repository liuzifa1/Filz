    "Add one or more attachments before sending.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "送信する前に添付ファイルを追加してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先添加一个或多个附件。"
          }
        }
      }
    },
    "Add photos, videos, files, or text to continue.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "続けるには写真、ビデオ、ファイル、またはテキストを追加してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加照片、视频、文件或文本以继续。"
          }
        }
      }
    },
