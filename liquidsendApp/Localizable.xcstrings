          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收藏"
          }
        }
      }
    },
    "File access is used only for files you select, receive, or share into the app.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルへのアクセスは、選択、受信、またはこのアプリに共有したファイルにのみ使用されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件访问权限仅用于你选择、接收或共享到本应用的文件。"
          }
        }
      }
    },
    "Files": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイル"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件"
          }
        }
      }
    },
    "Files and text are transferred directly between devices on your local network. Filz! does not upload your files to a cloud service or route them through a Filz! server.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルとテキストはローカルネットワーク上のデバイス間で直接転送されます。Filz!はファイルをクラウドサービスへアップロードしたり、Filz!サーバーを経由させたりしません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件和文本会在本地网络中的设备之间直接传输。Filz! 不会将文件上传到云服务，也不会通过 Filz! 服务器中转。"
          }
        }
      }
    },
    "Files shared to Filz! are kept only as needed to prepare and send the transfer.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz!に共有されたファイルは、転送の準備と送信に必要な間だけ保持されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "共享到 Filz! 的文件只会在准备和发送传输所需的时间内保留。"
          }
        }
      }
    },
    "Filter": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フィルタ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "筛选"
          }
        }
      }
    },
    "Filter history": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "履歴を絞り込む"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "筛选历史记录"
          }
        }
      }
    },
    "Filz can automatically add received photos and videos to your Photos library.": {
      "extractionState": "stale",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filzは受信した写真やビデオを写真ライブラリへ自動的に追加できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz 可以自动将收到的照片和视频添加到你的“照片”图库。"
          }
        }
      }
    },
    "Filz is a open source project aims to provide a native LocalSend experience on iOS.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filzは、iOSでネイティブなLocalSend体験を提供することを目的としたオープンソースプロジェクトです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz 是一个开源项目，旨在 iOS 上提供原生的 LocalSend 体验。"
          }
        }
      }
    },
    "Filz is ready to send files to and receive files from LocalSend on your other devices.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filzから他のデバイス上のLocalSendへファイルを送受信できるようになりました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz 已准备好与其他设备上的 LocalSend 收发文件。"
          }
        }
      }
    },
    "Filz needs Local Network access to discover LocalSend devices on your Wi-Fi and transfer files directly between them. Your files never leave your local network.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filzは、Wi-Fi上のLocalSendデバイスを検出し、デバイス間でファイルを直接転送するためにローカルネットワークへのアクセスが必要です。ファイルがローカルネットワークの外部に送信されることはありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz 需要“本地网络”访问权限，才能发现 Wi-Fi 网络中的 LocalSend 设备并在设备之间直接传输文件。你的文件不会离开本地网络。"
          }
        }
      }
    },
    "Filz!": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz!"
          }
        }
      }
    },
    "Filz! does not collect, sell, share, or track user data.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz!はユーザーデータを収集、販売、共有、追跡しません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz! 不会收集、出售、共享或跟踪用户数据。"
          }
        }
      }
    },
    "Filz! is built with open source software. This page lists the upstream LocalSend project and the resolved Rust crates used by the iOS LocalSend Core build.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz!はオープンソースソフトウェアで構築されています。このページには、上流のLocalSendプロジェクトとiOS LocalSend Coreのビルドで使用されるRustクレートを掲載しています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz! 使用开源软件构建。此页面列出了上游 LocalSend 项目，以及 iOS LocalSend Core 构建所使用的 Rust 软件包。"
          }
        }
      }
    },
    "Find Nearby Devices": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くのデバイスを探す"
