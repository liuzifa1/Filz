      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "もう一度確認"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "再次检查"
          }
        }
      }
    },
    "Checking Access…": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセスを確認中…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在检查权限…"
          }
        }
      }
    },
    "Filz couldn’t confirm Local Network access. Check that your device is connected to a network, then try again.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filzはローカルネットワークへのアクセスを確認できませんでした。デバイスがネットワークに接続されていることを確認してから、もう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz 无法确认本地网络访问权限。请检查设备是否已连接到网络，然后重试。"
          }
        }
      }
    },
    "Local Network Access Is Off": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルネットワークアクセスがオフです"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地网络访问已关闭"
          }
        }
      }
    },
    "Open Settings": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定を開く"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开设置"
          }
        }
      }
    },
    "Without Local Network access, Filz can’t discover nearby LocalSend devices, send files, or receive files. Turn it on in Settings to continue setup.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルネットワークへのアクセスがないと、Filzは近くのLocalSendデバイスを検出したり、ファイルを送受信したりできません。設定でアクセスをオンにして、セットアップを続けてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果没有本地网络访问权限，Filz 将无法发现附近的 LocalSend 设备，也无法发送或接收文件。请在“设置”中开启权限以继续设置。"
          }
        }
      }
    },
