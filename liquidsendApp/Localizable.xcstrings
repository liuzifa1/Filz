    "Cargo metadata is the source of package names, versions, authors, license expressions, descriptions, and repository links. Complete license terms remain available from each project source. Third-party copyright notices remain the property of their respective owners.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パッケージ名、バージョン、作者、ライセンス表記、説明、リポジトリへのリンクはCargoメタデータに基づいています。完全なライセンス条項は各プロジェクトのソースで確認できます。第三者の著作権表示は各権利者に帰属します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "软件包名称、版本、作者、许可证标识、说明和代码仓库链接均来自 Cargo 元数据。完整许可证条款可在各项目源代码中查看。第三方版权声明归其各自所有者所有。"
          }
        }
      }
    },
    "Change Device Name": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス名を変更"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更改设备名称"
          }
        }
      }
    },
    "Change the search or filter.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検索条件またはフィルタを変更してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请更改搜索内容或筛选条件。"
          }
        }
      }
    },
    "Check if both devices are on the same network.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方のデバイスが同じネットワークに接続されているか確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请确认两台设备连接到同一网络。"
          }
        }
      }
    },
    "Choose a Website Download": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Webサイトからダウンロードを選ぶ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
