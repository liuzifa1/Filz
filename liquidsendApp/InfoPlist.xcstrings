    "NSLocalNetworkUsageDescription": {
      "comment": "Privacy - Local Network Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Filz! uses your local network to discover nearby devices and transfer files."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz! 使用本地网络来发现附近设备并传输文件。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Filz!は近くのデバイスの検出とファイル転送のためにローカルネットワークを使用します。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription": {
      "comment": "Privacy - Photo Library Additions Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Filz! can save received photos and videos to your photo library when Save media to gallery is enabled."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用“将媒体保存到图库”后，Filz! 可以将收到的照片和视频保存到你的“照片”图库。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「メディアを写真に保存」が有効な場合、Filz!は受信した写真やビデオを写真ライブラリへ保存できます。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
